{
  "name": "@plentymarkets/unleash",
  "version": "1.0.0",
  "description": "Nuxt module for Unleash feature flags — PlentyONE Shop",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/module.mjs",
      "types": "./dist/types.d.mts"
    }
  },
  "main": "./dist/module.mjs",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "nuxt-module-build build",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare",
    "postinstall": "nuxt-module-build build --stub && nuxt-module-build prepare",
    "prepack": "nuxt-module-build build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@unleash/proxy-client-vue": "^0.1.6"
  },
  "devDependencies": {
    "@nuxt/kit": "^4.4.6",
    "@nuxt/module-builder": "^1.0.0",
    "@nuxt/schema": "^4.4.6",
    "nuxt": "^4.4.6"
  },
  "peerDependencies": {
    "nuxt": ">=3.0.0"
  },
  "author": "PlentyONE GmbH",
  "license": "BSD-3-Clause"
}
