{
  "name": "server",
  "version": "1.15.0",
  "main": "./src/index.ts",
  "license": "BSD-3-Clause",
  "scripts": {
    "dev": "nodemon",
    "start": "echo \"Starting server...\" && nodemon --spawn",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:start:prod": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop plentyshop-middleware",
    "pm2:restart": "pm2 restart plentyshop-middleware",
    "pm2:reload": "pm2 reload plentyshop-middleware",
    "pm2:delete": "pm2 delete plentyshop-middleware",
    "pm2:logs": "pm2 logs plentyshop-middleware",
    "pm2:monit": "pm2 monit",
    "pm2:status": "pm2 describe plentyshop-middleware",
    "lint": "echo \"No linting configured for server app\"",
    "lint:fix": "echo \"No linting configured for server app\"",
    "build": "tsup --minify"
  },
  "dependencies": {
    "@types/cors": "^2.8.17",
    "@vue-storefront/middleware": "5.4.1",
    "consola": "^3.2.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "nodemon": "^3.1.11",
    "ts-node-dev": "^2.0.0",
    "tsup": "^8.5.1"
  }
}
