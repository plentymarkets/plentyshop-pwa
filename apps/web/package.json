{
  "name": "web",
  "type": "module",
  "version": "1.15.0",
  "private": true,
  "license": "BSD-3-Clause",
  "scripts": {
    "build": "tsx ./build/index.ts && nuxt build",
    "dev": "tsx ./build/index.ts && npm run check:optimize-deps && nuxt dev",
    "start": "nuxt start",
    "generate": "nuxt generate",
    "publish-typedoc": "npx typedoc --options typedoc.json && mkdir -p docs/reference && rsync -av --delete reference/composables/ docs/reference/composables/",
    "lint": "nuxi prepare && eslint . --max-warnings 0",
    "lint:fix": "nuxi prepare && eslint . --fix --max-warnings 0",
    "typecheck": "nuxi prepare && vue-tsc --noEmit",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:cypress-dev": "cypress open --e2e",
    "test:cypress": "cypress run --browser chrome --headless --spec '__tests__/test/paypal/*.cy.{js,jsx,ts,tsx},__tests__/test/dhl/*.cy.{js,jsx,ts,tsx},__tests__/test/feature/*.cy.{js,jsx,ts,tsx},__tests__/test/checkout/*.cy.{js,jsx,ts,tsx},__tests__/test/editor/*.cy.{js,jsx,ts,tsx}'",
    "test:cypress-smoke-shop": "cypress run --browser chrome --headless --spec '__tests__/test/smoke/shop.cy.ts'",
    "test:cypress-smoke-editor": "cypress run --browser chrome --headless --spec '__tests__/test/smoke/editor.cy.ts'",
    "test:cypress-quarantine": "cypress run --browser chrome --headless --spec '__tests__/test/quarantine/*.cy.{js,jsx,ts,tsx}'",
    "test:cypress-post-quarantine": "cypress run --browser chrome --headless --spec '__tests__/test/post-quarantine/*.cy.{js,jsx,ts,tsx}'",
    "check:optimize-deps": "tsx ./build/check-optimize-deps.ts"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@nuxt/fonts": "^0.14.0",
    "@plentymarkets/tailwind-colors": "^1.0.1",
    "@types/js-beautify": "^1.14.3",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.17.0",
    "codemirror": "^6.0.2",
    "js-beautify": "^1.15.4",
    "nuxt-lazy-hydrate": "^1.0.0",
    "uuid": "^13.0.1",
    "validator": "^13.15.35"
  },
  "devDependencies": {
    "@mdi/js": "^7.4.47",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/image": "^1.11.0",
    "@nuxt/test-utils": "3.21.0",
    "@nuxtjs/i18n": "^10.3.0",
    "@nuxtjs/tailwindcss": "^6.12.0",
    "@savvywombat/tailwindcss-grid-areas": "^3.1.0",
    "@storefront-ui/typography": "^2.6.1",
    "@storefront-ui/vue": "^2.6.3",
    "@tailwindcss/container-queries": "^0.1.1",
    "@types/node": "^24.9.1",
    "@types/validator": "^13.15.10",
    "@vite-pwa/nuxt": "^1.0.4",
    "@vitest/coverage-v8": "^3.0.5",
    "@vue-storefront/eslint-config": "^5.1.1",
    "@vue-storefront/middleware": "5.4.1",
    "@vue-storefront/unified-data-model": "^3.0.0",
    "@vue/test-utils": "^2.4.10",
    "cypress": "15.16.0",
    "cypress-real-events": "^1.15.0",
    "cypress-wait-until": "^2.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "happy-dom": "^20.9.0",
    "msw": "^2.14.6",
    "nuxt": "^4.4.6",
    "sass": "^1.99.0",
    "tsx": "^4.21.1",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.5",
    "vuepress": "^2.0.0-rc.24",
    "vuetify-nuxt-module": "^0.19.4"
  }
}
