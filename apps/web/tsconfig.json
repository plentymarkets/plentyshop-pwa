{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "types": [
      "vitest/globals",
      "@vite-pwa/nuxt",
      "@types/applepayjs",
      "@types/googlepay",
      "@plentymarkets/shop-api/server/types"
    ],
    "verbatimModuleSyntax": false,
    "noImplicitAny": true
    // "typeRoots": ["./node_modules/@plentymarkets/shop-api/server/types", "./node_modules/@types"]
  },
  "exclude": ["node_modules", "mocks", "__tests__", "cypress.config.ts"],
  "typedocOptions": {
    "entryPoints": ["composables/index.ts"],
    "out": "reference/composables",
    "excludeExternals": true,
    "plugin": ["typedoc-plugin-markdown", "typedoc-vitepress-theme"],
    "githubPages": false,
    "readme": "none"
  }
}
