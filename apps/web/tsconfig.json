{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    // "baseUrl": ".",
    // "paths": {
    //   "@plentymarkets/pwa-module-boilerplate/*": ["../pwa-module-boilerplate/dist/*"]
    // },
    // "paths": {
    //   "@plentymarkets/pwa-module-boilerplate": ["node_modules/@plentymarkets/pwa-module-boilerplate/dist"]
    // },
    "types": [
      "@nuxt/kit",
      "@nuxt/schema",
      "vitest/globals",
      "@vite-pwa/nuxt",
      "@types/applepayjs",
      "@types/googlepay"
      // "@plentymarkets/pwa-module-boilerplate"
    ],
    "verbatimModuleSyntax": false
  },
  "exclude": ["node_modules", "mocks", "__tests__", "cypress.config.ts"],
  "typedocOptions": {
    "entryPoints": ["composables/index.ts"],
    "out": "reference/composables",
    "excludeExternals": true,
    "plugin": ["typedoc-plugin-markdown", "typedoc-vitepress-theme"],
    "githubPages": false,
    "readme": "none"
  }
}
